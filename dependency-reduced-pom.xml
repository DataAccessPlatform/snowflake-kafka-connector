              </includes>
              <excludes>
                <exclude>**/*Iceberg*IT.java</exclude>
              </excludes>
              <skipTests>${skipIntegrationTests}</skipTests>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
